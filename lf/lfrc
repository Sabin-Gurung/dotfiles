cmd create ${{
    [ -z "$1" ] && exit 0
    case "$1" in
        */) mkdir -p "$1" ;;
        *)  mkdir -p "$(dirname "$1")" && touch "$1" ;;
    esac
}}

map a push :create<space>

map D delete

cmd cpd ${{
    selected="$(fd .git$ -t d -H ~/workspace | sed 's/.git\///g' | fzf --height 45% --reverse)"
    [ -d "$selected" ] && cmd=cd || cmd=select
    lf -remote "send $id $cmd '$selected'"
}}

cmd cdd ${{
    lf -remote "send $id cd ~/Downloads/"
}}

